# Copy this file to ns_cinema_service/.env before running the service.

# Service
PORT=3001

# Database
# Replace placeholders with your real MongoDB connection details.
MONGODB_URI=mongodb://<username>:<password>@<host>:27017/<cinema_database>?authSource=admin
BACKEND_MONGODB_URI=mongodb://<username>:<password>@<host>:27017/<backend_database>?authSource=admin

# Optional: used by src/seed.ts to fetch movie runtimes from TMDB.
# If blank, the seed script falls back to a default runtime.
# Get a TMDB API key from your TMDB account settings -> API:
# - https://developer.themoviedb.org/docs/getting-started
# - https://developer.themoviedb.org/docs/authentication-application
TMDB_API=
