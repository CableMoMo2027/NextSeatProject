# Copy this file to ns_payment_service/.env before running the service.

# Service
PORT=3002

# Database
# Replace placeholders with your real MongoDB connection details.
MONGODB_URI=mongodb://<username>:<password>@<host>:27017/<database>?authSource=admin

# Merchant / receiving account
# The active TypeScript payment service does not require an external API key right now.
# Fill in your PromptPay or bank account details for QR generation and slip validation.
PROMPTPAY_ID=xxxxxxxxxx
MERCHANT_PROMPTPAY_ID=
MERCHANT_BANK_ACCOUNT=xxxxxxxxxx
MERCHANT_BANK_CODE=011
MERCHANT_ACCOUNT_NAME=NextSeat Merchant

# If true, uploaded slip amount must match the order amount exactly.
SLIP_REQUIRE_AMOUNT_MATCH=false

# Legacy express adapter variables below are not used by src/ right now,
# but are kept here because express-payment/ references them.
BASE_URL=http://localhost:3002
BANK_ACCOUNT_NUMBER=xxxxxxxxxx
BANK_CODE=011

# Optional future integration only:
# src/payment/payment.service.ts contains commented SlipOK variables.
# If you re-enable that path, get values from SlipOK:
# Docs: https://slipok.com/api-documentation/check-slip/
# SLIPOK_API_KEY=
# SLIPOK_BRANCH_ID=
