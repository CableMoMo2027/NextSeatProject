# Copy this file to ns_frontend/.env.local (recommended) or ns_frontend/.env.

# No MongoDB connection is used directly in the frontend.
VITE_API_BASE=https://api.cableskr.space

# Firebase Web App config
# Get all values below from Firebase Console:
# Project settings -> Your apps -> select Web app -> SDK setup and configuration -> Config
# Docs:
# - https://firebase.google.com/docs/web/learn-more
# - https://firebase.google.com/docs/projects/api-keys
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: payment service base URL used by src/services/paymentApi.js
VITE_PAYMENT_API_BASE=http://localhost:3002

# Optional: redirect URL used by Firebase email verification / password reset flows
VITE_AUTH_ACTION_URL=http://localhost:5173/login
