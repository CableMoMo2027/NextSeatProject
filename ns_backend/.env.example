# Copy this file to ns_backend/.env before running the service.

# Service
PORT=3000

# Database
# Replace placeholders with your real MongoDB connection details.
MONGODB_URI=mongodb://<username>:<password>@<host>:27017/<database>?authSource=admin

# Internal service URLs
CINEMA_SERVICE_URL=http://localhost:3001
PAYMENT_SERVICE_URL=http://localhost:3002

# Used by src/payments/payments.service.ts as the full internal payment base URL.
BACKEND_URI=http://localhost:3002/internal

# Email validation provider
# Set to "abstract" to enable external email validation, or "none" to disable it.
EMAIL_VALIDATION_PROVIDER=none

# Get this key from Abstract API Email Reputation:
# Docs: https://docs.abstractapi.com/email-reputation
# Dashboard: https://app.abstractapi.com/
EMAIL_VALIDATION_API_KEY=

# Optional tuning
EMAIL_VALIDATION_TIMEOUT_MS=5000
EMAIL_VALIDATION_CACHE_TTL_SEC=21600
EMAIL_VALIDATION_FAIL_OPEN=true
